# uFawkesSec — Infisical environment variables
# Copy to .env and fill in values before running:
#   cp config/infisical/.env.example .env
#
# Required:
INFISICAL_ENCRYPTION_KEY=<generate with: openssl rand -hex 32>
INFISICAL_AUTH_SECRET=<generate with: openssl rand -hex 64>
INFISICAL_DB_PASSWORD=<choose a strong password>
