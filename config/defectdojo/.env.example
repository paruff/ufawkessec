# uFawkesSec — DefectDojo environment variables
# Copy to .env and fill in values before running:
#   cp config/defectdojo/.env.example .env
#
# Required:
DEFECTDOJO_SECRET_KEY=<generate with: openssl rand -hex 64>
DEFECTDOJO_AES_KEY=<generate with: openssl rand -hex 32>
DOJO_DB_PASSWORD=<choose a strong password>

# Optional:
# FALCO_WEBHOOK_URL=https://hooks.example.com/alerts
